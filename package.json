{
  "name": "remote-agent-console",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @rac/server --filter @rac/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @rac/server test",
    "test:coverage": "pnpm --filter @rac/server test:coverage",
    "test:e2e": "pnpm --filter @rac/web test:e2e",
    "start": "pnpm --filter @rac/server start"
  }
}
