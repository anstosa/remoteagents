# Generate with: node -e "require('argon2').hash('change-me',{type:require('argon2').argon2id}).then(console.log)"
# Wrap the value in single quotes when Docker Compose will read this file.
RAC_PASSWORD_HASH=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
RAC_SESSION_SECRET=
RAC_CONFIG=/absolute/path/remote-agent-console.json
RAC_LOG_LEVEL=info
# Docker Compose only: UID that owns the host tmux server (normally 1000).
HOST_UID=1000

# Docker Compose only: absolute host path of the tunnel credentials JSON.
CLOUDFLARED_CREDENTIALS_FILE=/absolute/path/.cloudflared/tunnel-uuid.json
